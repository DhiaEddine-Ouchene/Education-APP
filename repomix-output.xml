  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-main);
}
::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 9999px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--text-muted);
}

/* Typography Utility */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  color: var(--text-main);
}

/* Base Components */
input, select, textarea {
  font-family: inherit;
  color: inherit;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes popIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes pulseSuccess {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
  50% { transform: scale(1.03); box-shadow: 0 0 12px 6px rgba(16, 185, 129, 0.2); }
}

@keyframes shakeError {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-6px); }
  40%, 80% { transform: translateX(6px); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.animate-fade {
  animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.animate-scale {
  animation: scaleIn 0.25s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* RTL Helpers */
[dir="rtl"] {
  direction: rtl;
  text-align: right;
}

/* Flex Center Helper */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* CARD ITEMS */
.card-item {
  background-color: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card-item.hover-translate:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-color);
}

.text-muted {
  color: var(--text-muted);
}

.text-success {
  color: var(--color-success);
}

/* ALERT NOTIFICATIONS */
.error-alert {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
  border: 1px solid rgba(239, 68, 68, 0.2);
  padding: 12px 18px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
}

.success-alert {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success);
  border: 1px solid rgba(16, 185, 129, 0.2);
  padding: 12px 18px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
}

/* BUTTONS SYSTEM */
.action-button-primary {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border: none;
  font-weight: 600;
  padding: 10px 20px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: opacity 0.15s ease;
  box-shadow: 0 2px 4px var(--primary-glow);
}
.action-button-primary:hover:not(:disabled) {
  opacity: 0.9;
}
.action-button-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.action-button-secondary {
  background-color: var(--bg-card);
  color: var(--text-main);
  border: 1px solid var(--border-color);
  font-weight: 600;
  padding: 10px 20px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background-color 0.15s ease;
}
.action-button-secondary:hover:not(:disabled) {
  background-color: var(--bg-main);
}
.action-button-secondary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.action-button-danger {
  background-color: var(--color-error);
  color: #FFFFFF;
  border: none;
  font-weight: 600;
  padding: 10px 15px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: opacity 0.15s ease;
}
.action-button-danger:hover {
  opacity: 0.9;
}

/* SIDEBAR LAYOUT STYLING */
.app-sidebar {
  width: 260px;
  background-color: var(--bg-sidebar);
  color: #94A3B8;
  display: flex;
  flex-direction: column;
  height: 100vh;
  border-right: 1px solid var(--border-color);
  flex-shrink: 0;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 100;
}

.sidebar-brand {
  padding: 24px;
  border-bottom: 1px solid #1E293B;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sidebar-logo {
  max-height: 40px;
  align-self: flex-start;
}

.sidebar-logo-fallback {
  display: flex;
  align-items: center;
  gap: 10px;
}

.sidebar-logo-fallback .brand-text {
  font-family: 'Outfit', sans-serif;
  font-size: 22px;
  font-weight: 800;
  color: #FFFFFF;
}

.sidebar-tenant-name {
  font-size: 11px;
  font-weight: 700;
  color: var(--primary-color);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.sidebar-user-card {
  padding: 15px 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid #1E293B;
}

.user-avatar {
  width: 38px;
  height: 38px;
  background-color: var(--primary-color);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 16px;
}

.user-details {
  overflow: hidden;
}

.user-name {
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.user-role-badge {
  font-size: 10px;
  text-transform: uppercase;
  background: rgba(255, 255, 255, 0.1);
  padding: 2px 6px;
  border-radius: 4px;
  align-self: flex-start;
  margin-top: 2px;
  display: inline-block;
}

.sidebar-nav {
  flex: 1;
  padding: 20px 0;
  overflow-y: auto;
}

.sidebar-nav ul {
  list-style: none;
}

.sidebar-nav-btn {
  width: 100%;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 500;
  color: #94A3B8;
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: left;
}

.sidebar-nav-btn:hover {
  color: #FFFFFF;
  background-color: rgba(255, 255, 255, 0.05);
}

.sidebar-nav-btn.active {
  background-color: rgba(255, 255, 255, 0.07);
}

.nav-icon {
  flex-shrink: 0;
}

.sidebar-footer {
  padding: 15px 24px;
  border-top: 1px solid #1E293B;
}

.sidebar-logout-btn {
  background: transparent;
  border: none;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12px;
  color: #94A3B8;
  cursor: pointer;
  font-size: 14px;
  padding: 10px 0;
  transition: color 0.15s ease;
}

.sidebar-logout-btn:hover {
  color: #EF4444;
}

/* LOGIN SCREEN STYLING */
.login-page-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  position: relative;
  background-color: var(--bg-main);
  overflow: hidden;
  padding: 20px;
}

.bg-blob-1, .bg-blob-2 {
  position: absolute;
  width: 450px;
  height: 450px;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.12;
  z-index: 0;
}

.bg-blob-1 {
  background: var(--primary-color);
  top: -10%;
  right: -5%;
}

.bg-blob-2 {
  background: var(--secondary-color);
  bottom: -10%;
  left: -5%;
}

.login-card-wrapper {
  max-width: 420px;
  width: 100%;
  border-radius: var(--radius-lg);
  padding: 40px;
  position: relative;
  z-index: 10;
  border: 1px solid var(--border-color);
  background-color: var(--bg-card);
  box-shadow: var(--shadow-lg);
}

.login-header {
  text-align: center;
  margin-bottom: 30px;
}

.login-tenant-logo {
  max-height: 55px;
  margin-bottom: 15px;
}

.login-logo-fallback {
  width: 65px;
  height: 65px;
  background-color: var(--primary-glow);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 15px;
}

.login-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 6px;
}

.login-subtitle {
  font-size: 13px;
  color: var(--text-muted);
}

.login-error-card {
  background-color: rgba(239, 68, 68, 0.08);
  color: var(--color-error);
  border: 1px solid rgba(239, 68, 68, 0.15);
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 22px;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.login-input-group {
  display: flex;
  flex-direction: column;
}

.login-input-group label {
  font-size: 12px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 6px;
  text-transform: uppercase;
}

.input-with-icon {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 12px;
  color: var(--text-muted);
}

.input-with-icon input, .form-input-control {
  width: 100%;
  padding: 10px 12px 10px 40px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  outline: none;
  font-size: 14px;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

.form-input-control {
  padding-left: 12px; /* For standard input without left icons */
}

.input-with-icon input:focus, .form-input-control:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3px var(--primary-glow);
}

.login-submit-btn {
  color: #FFFFFF;
  border: none;
  font-size: 15px;
  font-weight: 700;
  padding: 12px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s ease;
  box-shadow: 0 4px 6px -1px var(--primary-glow);
  margin-top: 10px;
}

.login-submit-btn:hover {
  opacity: 0.9;
}

.login-footer {
  text-align: center;
  margin-top: 24px;
  font-size: 13px;
  color: var(--text-muted);
}

.login-text-link {
  background: transparent;
  border: none;
  color: var(--primary-color);
  font-weight: 600;
  cursor: pointer;
  font-size: inherit;
}
.login-text-link:hover {
  text-decoration: underline;
}

.tenant-slug-selector {
  display: flex;
}

.tenant-slug-input {
  flex: 1;
  padding: 6px 10px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 13px;
  outline: none;
}

.tenant-slug-btn {
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  padding: 6px 12px;
  border-radius: var(--radius-sm);
  font-weight: 600;
  cursor: pointer;
}

/* ADMIN PANEL TABLES */
.admin-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
}

.admin-table th {
  padding: 12px 16px;
  border-bottom: 2px solid var(--border-color);
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  color: var(--text-muted);
}

.admin-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-color);
  font-size: 14px;
}

.table-hover-row:hover {
  background-color: var(--bg-main);
}

/* SUBSCRIPTION TIER BADGES */
.plan-badge {
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  display: inline-block;
}

.plan-badge.free {
  background-color: #E2E8F0;
  color: #475569;
}

.plan-badge.pro {
  background-color: var(--primary-glow);
  color: var(--primary-color);
}

.plan-badge.school {
  background-color: rgba(16, 185, 129, 0.15);
  color: #10B981;
}

/* STATS COUNTERS CARDS */
.stats-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 15px;
  box-shadow: var(--shadow-sm);
}

.stats-card.highlight-revenue {
  border-left: 5px solid #10B981;
}

.stats-icon-wrapper {
  width: 48px;
  height: 48px;
  background-color: var(--bg-main);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-color);
  flex-shrink: 0;
}

.stats-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.stats-value {
  font-size: 24px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 4px;
}

.stats-change {
  font-size: 11px;
  color: var(--text-muted);
}

/* PRICING PLANS GRID */
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.active-tier-card {
  border: 2px solid var(--primary-color) !important;
  box-shadow: var(--shadow-lg) !important;
  position: relative;
}

.active-tier-card::after {
  content: 'Active Plan';
  position: absolute;
  top: 12px;
  right: 12px;
  background: var(--primary-color);
  color: #FFFFFF;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 4px;
  text-transform: uppercase;
}

/* PRONUNCIATION SPEAKER BUTTON */
.tts-button {
  background: var(--primary-glow);
  color: var(--primary-color);
  border: none;
  padding: 8px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, background 0.15s ease;
}

.tts-button:hover {
  transform: scale(1.1);
  background: var(--primary-color);
  color: #FFFFFF;
}

.tts-button.active {
  animation: pulseSuccess 1s infinite;
}

.lang-tag {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
}

/* MODAL VANILLA STYLING */
.modal-wrapper {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.modal-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(4px);
}

.modal-container {
  background-color: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  width: 100%;
  max-width: 550px;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 60;
  overflow: hidden;
}

.modal-header {
  padding: 16px 24px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
}

.modal-close-btn {
  background: transparent;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  padding: 4px;
  border-radius: 4px;
  display: flex;
  align-items: center;
}
.modal-close-btn:hover {
  background-color: var(--bg-main);
  color: var(--text-main);
}

.modal-body {
  padding: 24px;
  overflow-y: auto;
  flex: 1;
}

/* HTML Form Utilities inside Modals */
.form-layout {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.form-group label {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 6px;
  display: block;
}

/* ─── PAGE HEADER ─────────────────────────────────────────────────── */
.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 28px;
}

.page-title {
  font-size: 26px;
  font-weight: 800;
  color: var(--text-main);
  line-height: 1.2;
}

.page-subtitle {
  font-size: 14px;
  color: var(--text-muted);
  margin-top: 4px;
}

/* ─── DASHBOARD LAYOUT ─────────────────────────────────────────────── */
.dashboard-layout {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background: var(--bg-main);
}

.dashboard-main {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.dashboard-content {
  flex: 1;
  padding: 32px;
  max-width: 1280px;
  width: 100%;
  margin: 0 auto;
  animation: fadeIn 0.3s ease;
}

.dashboard-topbar {
  padding: 14px 32px;
  border-bottom: 1px solid var(--border-color);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-shrink: 0;
}

.topbar-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-main);
}

/* ─── STATS GRID ───────────────────────────────────────────────────── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin-bottom: 32px;
}

/* ─── CONTENT GRID ─────────────────────────────────────────────────── */
.content-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}

/* ─── TABS ─────────────────────────────────────────────────────────── */
.tabs-bar {
  display: flex;
  border-bottom: 2px solid var(--border-color);
  margin-bottom: 28px;
  gap: 4px;
}

.tab-btn {
  background: transparent;
  border: none;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  transition: color 0.15s ease, border-color 0.15s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.tab-btn.active {
  color: var(--primary-color);
  border-bottom-color: var(--primary-color);
}

.tab-btn:hover:not(.active) {
  color: var(--text-main);
}

/* ─── TOAST NOTIFICATIONS ──────────────────────────────────────────── */
.toast-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.toast {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  font-size: 14px;
  font-weight: 500;
  animation: fadeIn 0.25s ease;
  min-width: 280px;
  max-width: 400px;
}

.toast.success {
  background: #052e16;
  color: #4ade80;
  border: 1px solid #166534;
}

.toast.error {
  background: #2d0707;
  color: #f87171;
  border: 1px solid #991b1b;
}

.toast.info {
  background: #0c1a2e;
  color: #93c5fd;
  border: 1px solid #1e3a5f;
}

/* ─── LOADING SPINNER ──────────────────────────────────────────────── */
.loading-spinner {
  display: inline-block;
  width: 20px;
  height: 20px;
  border: 2px solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

.loading-fullpage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 16px;
  color: var(--text-muted);
  font-size: 15px;
}

.loading-fullpage .loading-spinner {
  width: 40px;
  height: 40px;
  border-width: 3px;
}

/* ─── EMPTY STATE ──────────────────────────────────────────────────── */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--text-muted);
}

.empty-state-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-state h3 {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8px;
}

.empty-state p {
  font-size: 14px;
  max-width: 300px;
  margin: 0 auto 20px;
}

/* ─── WORD SET CARD ────────────────────────────────────────────────── */
.set-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 20px;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.set-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-color);
}

.set-card-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-main);
}

.set-card-meta {
  font-size: 12px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 8px;
}

.set-card-actions {
  display: flex;
  gap: 8px;
  margin-top: auto;
}

/* ─── GAME PLAYER ──────────────────────────────────────────────────── */
.game-container {
  min-height: 100vh;
  background: var(--bg-main);
  display: flex;
  flex-direction: column;
}

.game-topbar {
  padding: 16px 24px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.game-title {
  font-size: 18px;
  font-weight: 700;
}

.game-area {
  flex: 1;
  padding: 32px 24px;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
}

.game-progress-bar-wrapper {
  height: 6px;
  background: var(--border-color);
  border-radius: 9999px;
  margin-bottom: 24px;
  overflow: hidden;
}

.game-progress-bar-fill {
  height: 100%;
  background: var(--primary-color);
  border-radius: 9999px;
  transition: width 0.4s ease;
}

/* ─── MATCHING GAME GRID ────────────────────────────────────────────── */
.matching-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 14px;
}

.matching-card {
  aspect-ratio: 4/3;
  border: 2px solid var(--border-color);
  border-radius: var(--radius-md);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.18s ease;
  user-select: none;
}

.matching-card:hover {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3px var(--primary-glow);
}

.matching-card.selected {
  border-color: var(--primary-color);
  background: var(--primary-glow);
  animation: popIn 0.2s ease;
}

.matching-card.matched {
  border-color: var(--color-success);
  background: rgba(16, 185, 129, 0.1);
  animation: pulseSuccess 0.5s ease;
  cursor: default;
}

.matching-card.wrong {
  border-color: var(--color-error);
  background: rgba(239, 68, 68, 0.1);
  animation: shakeError 0.4s ease;
}

/* ─── FLASHCARD ─────────────────────────────────────────────────────── */
.flashcard-scene {
  perspective: 1200px;
  cursor: pointer;
  margin: 0 auto;
  width: 100%;
  max-width: 500px;
  height: 280px;
}

.flashcard-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

.flashcard-scene.flipped .flashcard-inner {
  transform: rotateY(180deg);
}

.flashcard-face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  background: var(--bg-card);
  border: 2px solid var(--border-color);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30px;
  box-shadow: var(--shadow-lg);
}

.flashcard-face.back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: #fff;
  border-color: transparent;
}

.flashcard-word {
  font-size: 32px;
  font-weight: 800;
  text-align: center;
}

.flashcard-hint {
  font-size: 13px;
  margin-top: 10px;
  opacity: 0.7;
  text-align: center;
}

.flashcard-label {
  font-size: 11px;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 1px;
  opacity: 0.6;
  margin-bottom: 12px;
}

.flashcard-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 24px;
}

/* ─── QUIZ & TYPE-IN ─────────────────────────────────────────────────── */
.quiz-question-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 32px;
  text-align: center;
  margin-bottom: 24px;
  box-shadow: var(--shadow-md);
}

.quiz-question-word {
  font-size: 36px;
  font-weight: 800;
  margin-bottom: 8px;
}

.quiz-options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.quiz-option-btn {
  padding: 16px;
  background: var(--bg-card);
  border: 2px solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: center;
  color: var(--text-main);
}

.quiz-option-btn:hover:not(:disabled) {
  border-color: var(--primary-color);
  background: var(--primary-glow);
}

.quiz-option-btn.correct {
  border-color: var(--color-success);
  background: rgba(16, 185, 129, 0.15);
  color: var(--color-success);
}

.quiz-option-btn.wrong {
  border-color: var(--color-error);
  background: rgba(239, 68, 68, 0.15);
  color: var(--color-error);
  animation: shakeError 0.4s ease;
}

/* ─── GAME RESULT SCREEN ────────────────────────────────────────────── */
.game-result {
  text-align: center;
  padding: 40px 20px;
  animation: fadeIn 0.4s ease;
}

.result-score-ring {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: conic-gradient(var(--primary-color) var(--pct), var(--border-color) 0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  font-size: 28px;
  font-weight: 800;
  position: relative;
}

.result-score-ring::before {
  content: '';
  position: absolute;
  inset: 10px;
  background: var(--bg-card);
  border-radius: 50%;
}

.result-score-text {
  position: relative;
  z-index: 1;
}

/* ─── BRANDING PANEL ────────────────────────────────────────────────── */
.branding-preview-panel {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: var(--radius-lg);
  padding: 28px;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 12px;
  box-shadow: var(--shadow-lg);
}

.color-picker-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.color-picker-swatch {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  border: none;
  cursor: pointer;
  padding: 2px;
}

/* ─── LESSON READER ─────────────────────────────────────────────────── */
.lesson-content {
  font-size: 15px;
  line-height: 1.8;
  color: var(--text-main);
  white-space: pre-wrap;
}

.lesson-content .vocab-highlight {
  background: var(--primary-glow);
  color: var(--primary-color);
  border-radius: 4px;
  padding: 1px 4px;
  font-weight: 700;
  cursor: help;
  transition: background 0.15s ease;
}

.lesson-content .vocab-highlight:hover {
  background: var(--primary-color);
  color: #fff;
}

/* ─── BILLING PORTAL ────────────────────────────────────────────────── */
.billing-feature-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin: 16px 0;
}

.billing-feature-list li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.billing-feature-list li::before {
  content: '✓';
  color: var(--color-success);
  font-weight: 800;
}

/* ─── REGISTER PAGE ─────────────────────────────────────────────────── */
.register-page-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  background: var(--bg-main);
  position: relative;
  overflow: hidden;
}

.register-card {
  width: 100%;
  max-width: 560px;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 40px;
  box-shadow: var(--shadow-lg);
  position: relative;
  z-index: 10;
  animation: scaleIn 0.3s ease;
}

.register-card h1 {
  font-size: 26px;
  margin-bottom: 6px;
}

.register-card p.subtitle {
  color: var(--text-muted);
  font-size: 14px;
  margin-bottom: 28px;
}

.two-col-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ─── GENERIC UTILITIES ─────────────────────────────────────────────── */
.inline-flex {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.mt-4 { margin-top: 16px; }
.mt-8 { margin-top: 32px; }
.mb-4 { margin-bottom: 16px; }
.mb-8 { margin-bottom: 32px; }
.gap-8 { gap: 8px; }
.gap-12 { gap: 12px; }
.flex { display: flex; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.w-full { width: 100%; }
.text-right { text-align: right; }
.font-bold { font-weight: 700; }
.text-sm { font-size: 13px; }
.text-xs { font-size: 11px; }

/* ─── APP LAYOUT CONTAINERS ─────────────────────────────────────────── */
.app-container {
  display: flex;
  min-height: 100vh;
  background-color: var(--bg-main);
}

.app-main-content {
  flex: 1;
  padding: 40px;
  overflow-y: auto;
  max-height: 100vh;
  transition: padding 0.25s ease, margin-top 0.25s ease;
}

/* ─── MOBILE SCENIC NAV TOP BAR ────────────────────────────────────── */
.mobile-header {
  display: none; /* Hidden on Desktop */
  height: 60px;
  background-color: var(--bg-card);
  border-bottom: 1px solid var(--border-color);
  padding: 0 20px;
  align-items: center;
  justify-content: space-between;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 90;
  box-shadow: var(--shadow-sm);
}

.sidebar-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(11, 15, 25, 0.45);
  backdrop-filter: blur(3px);
  z-index: 99;
  animation: fadeIn 0.2s ease-out;
}

/* ─── RESPONSIVE MEDIA BREAKPOINTS ──────────────────────────────────── */
@media (max-width: 1024px) {
  .app-sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    transform: translateX(-100%);
    height: 100vh;
    box-shadow: 4px 0 25px rgba(0, 0, 0, 0.15);
  }

  .app-sidebar.sidebar-open {
    transform: translateX(0);
  }

  .sidebar-close-btn {
    display: block !important; /* Make X button visible in sidebar on mobile */
  }

  .mobile-header {
    display: flex; /* Reveal mobile top bar */
  }

  .app-container {
    flex-direction: column;
  }

  .app-main-content {
    margin-top: 60px; /* Space for mobile header */
    padding: 24px;
  }

  .account-profile-grid,
  .account-branding-grid {
    grid-template-columns: 1fr !important;
    gap: 24px !important;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important;
  }

  .pricing-grid {
    grid-template-columns: 1fr !important;
    gap: 24px !important;
  }
}

@media (max-width: 768px) {
  .dashboard-layout { flex-direction: column; }
  .app-sidebar { width: 280px; } /* Drawer width on smaller tablets/phones */
  .dashboard-content { padding: 20px 16px; }
  .quiz-options-grid { grid-template-columns: 1fr; }
  .matching-grid { grid-template-columns: repeat(3, 1fr); }
  .two-col-form { grid-template-columns: 1fr; }
  .app-main-content { padding: 20px 15px; }
}

@media (max-width: 640px) {
  .stats-grid {
    grid-template-columns: 1fr !important;
  }
  
  .student-games-row {
    grid-template-columns: 1fr 1fr !important; /* 2x2 layout on phone screens */
    gap: 8px !important;
  }
  
  .sidebar-brand {
    padding: 18px 20px !important;
  }
  
  .sidebar-user-card {
    padding: 12px 20px !important;
  }
  
  .sidebar-nav-btn {
    padding: 10px 20px !important;
  }
}

/* ─── VOCABULARY GAME LAYOUTS & 3D FLIP CARDS ──────────────────────── */
.game-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
}

@media (max-width: 900px) {
  .game-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
}

@media (max-width: 600px) {
  .game-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
}

/* 3D Flip Card Container */
.memory-card {
  aspect-ratio: 1.1 / 1;
  perspective: 1200px;
  cursor: pointer;
  width: 100%;
  position: relative;
  user-select: none;
}

/* Outer container of flashcards might override aspect ratio if specified in style */
.memory-card[style*="height"] {
  aspect-ratio: auto;
}

/* Inner wrapper containing front & back */
.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  text-align: center;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}

/* Flip state classes */
.memory-card.flipped .card-inner,
.memory-card.flip .card-inner {
  transform: rotateY(180deg);
}

/* Card faces */
.card-front,
.card-back {
  position: absolute;
  inset: 0;
  -webkit-backface-visibility: hidden; /* Safari */
  backface-visibility: hidden;
  border-radius: var(--radius-md);
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18px;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

/* Front Face */
.card-front {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: #FFFFFF;
  border-color: transparent;
}

.card-front::after {
  content: 'EduMatch';
  position: absolute;
  bottom: 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  opacity: 0.35;
  text-transform: uppercase;
}

/* Back Face */
.card-back {
  background: var(--bg-card);
  color: var(--text-main);
  transform: rotateY(180deg);
}

/* Hover effect on cards */
.memory-card:hover .card-front {
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  transform: translateY(-2px);
}

.memory-card:hover .card-back {
  border-color: var(--primary-color);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

/* Matching Status Modifications */
.memory-card.matched .card-back {
  border-color: #10B981 !important;
  background: rgba(16, 185, 129, 0.08) !important;
  color: #10B981 !important;
  box-shadow: 0 0 12px rgba(16, 185, 129, 0.15) !important;
}

.memory-card.mismatched .card-back {
  border-color: #EF4444 !important;
  background: rgba(239, 68, 68, 0.08) !important;
  color: #EF4444 !important;
  animation: shakeError 0.4s ease;
}

/* Shaking Error Animation */
@keyframes shakeError {
  0%, 100% { transform: rotateY(180deg) translateX(0); }
  20%, 60% { transform: rotateY(180deg) translateX(-6px); }
  40%, 80% { transform: rotateY(180deg) translateX(6px); }
}

/* Pulsing Speaker Card styling for Listening Game */
.listening-speaker-pulse-card {
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.listening-speaker-pulse-card:hover {
  transform: scale(1.05) !important;
  box-shadow: 0 0 25px var(--primary-glow) !important;
}
