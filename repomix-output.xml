<file path="temp-games/edumatch-platform/public/css/styles.css">
/* EduMatch — modern UI. Org theme injects --primary / --accent at runtime. */
:root{
  --primary:#6366f1; --accent:#a855f7;
  --bg:#0a0c14; --bg1:#11141f; --bg2:#171b29; --bg3:#1f2435;
  --card:rgba(255,255,255,.03); --card-brd:rgba(255,255,255,.08);
  --txt:#eef1f8; --muted:#9aa3b8;
  --good:#22c55e; --warn:#f59e0b; --bad:#ef4444;
  --radius:18px; --radius-sm:12px;
  --shadow:0 10px 40px -12px rgba(0,0,0,.6);
  --ring:0 0 0 3px color-mix(in srgb, var(--primary) 30%, transparent);
  --font:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  font-family:var(--font); color:var(--txt); background:var(--bg);
  -webkit-font-smoothing:antialiased; line-height:1.5; min-height:100vh;
  background-image:
    radial-gradient(1100px 600px at 12% -8%, color-mix(in srgb,var(--primary) 16%,transparent), transparent 60%),
    radial-gradient(900px 600px at 100% 0%, color-mix(in srgb,var(--accent) 13%,transparent), transparent 55%);
}
body.light{
  --bg:#f5f6fb; --bg1:#ffffff; --bg2:#f2f4fa; --bg3:#e9edf6;
  --card:#ffffff; --card-brd:rgba(15,23,42,.08);
  --txt:#0f172a; --muted:#5b6577;
  --shadow:0 12px 40px -16px rgba(15,23,42,.22);
}
h1,h2,h3{margin:0 0 2px; letter-spacing:-.02em; font-weight:700}
h1{font-size:26px} h3{font-size:17px}
p{margin:0}
a{color:inherit}
.muted{color:var(--muted)}
.center{text-align:center}
.hidden{display:none!important}
.text-grad,.grad-text{background:linear-gradient(120deg,var(--primary),var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent}

/* ---------- inputs ---------- */
input,select,textarea{
  width:100%; padding:11px 13px; border-radius:var(--radius-sm);
  border:1px solid var(--card-brd); background:var(--bg2); color:var(--txt);
  font-family:inherit; font-size:14px; outline:none; transition:border-color .15s, box-shadow .15s;
}
input:focus,select:focus,textarea:focus{border-color:var(--primary); box-shadow:var(--ring)}
textarea{resize:vertical; line-height:1.6}
label.fld{display:block; font-size:12px; font-weight:600; color:var(--muted); margin:0 0 6px; text-transform:uppercase; letter-spacing:.04em}

/* ---------- buttons ---------- */
.btn{
  appearance:none; cursor:pointer; border:0; border-radius:999px;
  padding:11px 20px; font-size:14px; font-weight:600; font-family:inherit; color:#fff;
  background:linear-gradient(120deg,var(--primary),var(--accent));
  box-shadow:0 8px 22px -10px color-mix(in srgb,var(--primary) 80%,black);
  transition:transform .08s ease, box-shadow .15s, opacity .15s; white-space:nowrap;
}
.btn:hover{transform:translateY(-1px)}
.btn:active{transform:translateY(0)}
.btn:disabled{opacity:.5; cursor:default; transform:none; box-shadow:none}
.btn.secondary{background:var(--bg3); color:var(--txt); box-shadow:none; border:1px solid var(--card-brd)}
.btn.ghost{background:transparent; color:var(--muted); box-shadow:none}
.btn.ghost:hover{color:var(--txt); background:var(--bg2)}
.btn.good{background:linear-gradient(120deg,#16a34a,#22c55e); box-shadow:0 8px 22px -10px #16a34a}
.btn.sm{padding:7px 14px; font-size:13px}
.btn.lg{padding:14px 26px; font-size:16px}

.badge{display:inline-flex; align-items:center; gap:6px; padding:4px 11px; border-radius:999px; font-size:12px; font-weight:600; background:var(--bg3); color:var(--muted)}
.badge.good{background:color-mix(in srgb,var(--good) 18%,transparent); color:var(--good)}
.badge.warn{background:color-mix(in srgb,var(--warn) 18%,transparent); color:var(--warn)}

/* ---------- layout ---------- */
.row{display:flex; align-items:center; gap:10px; flex-wrap:wrap}
.spread{justify-content:space-between}
.spacer{flex:1}
.grid{display:grid; gap:16px}
.grid.cols-2{grid-template-columns:repeat(2,1fr)}
.grid.cols-3{grid-template-columns:repeat(3,1fr)}
.grid.cols-4{grid-template-columns:repeat(4,1fr)}
@media(max-width:860px){.grid.cols-2,.grid.cols-3,.grid.cols-4{grid-template-columns:1fr}}

.card{
  background:var(--card); border:1px solid var(--card-brd); border-radius:var(--radius);
  padding:20px; box-shadow:var(--shadow); backdrop-filter:blur(8px);
}
body.light .card{backdrop-filter:none}
.empty{padding:48px 20px; text-align:center; color:var(--muted); border:1px dashed var(--card-brd); border-radius:var(--radius)}

/* ---------- app shell ---------- */
.shell{display:flex; min-height:100vh}
.sidebar{
  width:248px; flex-shrink:0; padding:18px 14px; display:flex; flex-direction:column; gap:6px;
  background:color-mix(in srgb,var(--bg1) 80%,transparent); border-right:1px solid var(--card-brd);
  position:sticky; top:0; height:100vh;
}
.sidebar .org{display:flex; align-items:center; gap:11px; padding:8px 10px 16px; margin-bottom:6px; border-bottom:1px solid var(--card-brd)}
.sidebar .org img,.sidebar .org .logo{width:42px; height:42px; border-radius:12px; object-fit:cover; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:19px; color:#fff}
.sidebar .org .logo.grad,.logo.grad{background:linear-gradient(135deg,var(--primary),var(--accent))}
.sidebar .org b{font-size:15px; line-height:1.2; overflow:hidden; text-overflow:ellipsis; white-space:nowrap}
.navlink{
  display:flex; align-items:center; gap:11px; width:100%; text-align:left; cursor:pointer;
  padding:10px 12px; border-radius:12px; border:0; background:transparent; color:var(--muted);
  font-family:inherit; font-size:14px; font-weight:500; transition:background .12s,color .12s;
}
.navlink:hover{background:var(--bg2); color:var(--txt)}
.navlink.active{background:color-mix(in srgb,var(--primary) 16%,transparent); color:var(--txt); font-weight:600}
.navlink .ic{font-size:17px; width:22px; text-align:center}
.main{flex:1; padding:30px 38px; max-width:1180px; margin:0 auto; width:100%}
@media(max-width:760px){.sidebar{display:none}.main{padding:20px 16px}}
.page-head{display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:22px; flex-wrap:wrap}
.page-head .sub{color:var(--muted); font-size:14px; margin-top:4px}

/* ---------- stats ---------- */
.stat-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:8px}
@media(max-width:860px){.stat-grid{grid-template-columns:repeat(2,1fr)}}
.stat{background:var(--card); border:1px solid var(--card-brd); border-radius:var(--radius); padding:18px}
.stat .v{font-size:30px; font-weight:800; letter-spacing:-.03em; line-height:1}
.stat .l{color:var(--muted); font-size:13px; margin-top:7px}

/* ---------- tables / item rows ---------- */
.table{width:100%; border-collapse:collapse; font-size:14px}
.table th{text-align:left; color:var(--muted); font-weight:600; font-size:12px; text-transform:uppercase; letter-spacing:.04em; padding:10px 12px; border-bottom:1px solid var(--card-brd)}
.table td{padding:12px; border-bottom:1px solid var(--card-brd)}
.table tr:last-child td{border-bottom:0}
.item-row{display:grid; grid-template-columns:1fr 1fr 1fr auto; gap:8px; align-items:center; margin-bottom:8px}
.item-row .del{cursor:pointer; color:var(--muted); background:var(--bg2); border:1px solid var(--card-brd); border-radius:10px; padding:9px 12px}
.item-row .del:hover{color:var(--bad)}
@media(max-width:680px){.item-row{grid-template-columns:1fr 1fr}}

/* ---------- auth + landing ---------- */
.auth-wrap{min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px}
.auth-card{width:100%; max-width:420px; background:var(--card); border:1px solid var(--card-brd); border-radius:24px; padding:34px; box-shadow:var(--shadow); backdrop-filter:blur(10px)}
.logo-badge{width:56px; height:56px; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:28px; background:linear-gradient(135deg,var(--primary),var(--accent)); box-shadow:0 10px 30px -10px var(--primary); margin:0 auto 14px}
.hero{text-align:center; padding:70px 20px 40px; max-width:760px; margin:0 auto}
.hero h1{font-size:clamp(34px,6vw,58px); line-height:1.05; margin-bottom:18px}
.hero p{font-size:18px; color:var(--muted); max-width:560px; margin:0 auto 26px}
.feature-grid{max-width:1040px; margin:10px auto; padding:0 20px}
.feature{text-align:left}
.feature .ic{font-size:26px; width:52px; height:52px; display:flex; align-items:center; justify-content:center; border-radius:14px; background:var(--bg2); margin-bottom:12px}
.feature h3{margin-bottom:6px}

/* ---------- tabs ---------- */
.tabs{display:flex; gap:6px; background:var(--bg2); padding:5px; border-radius:14px; flex-wrap:wrap}
.tabs button{flex:1; min-width:90px; padding:9px 12px; border:0; background:transparent; color:var(--muted); font-family:inherit; font-size:13px; font-weight:600; border-radius:10px; cursor:pointer; transition:.12s}
.tabs button.active{background:linear-gradient(120deg,var(--primary),var(--accent)); color:#fff}

/* ---------- quiz / prompt ---------- */
.prompt-box{text-align:center; padding:30px 20px}
.prompt-box .big{font-size:clamp(30px,6vw,48px); font-weight:800; letter-spacing:-.02em}
.prompt-box .sub{color:var(--muted); margin-top:8px}
.opts{display:grid; grid-template-columns:repeat(2,1fr); gap:12px; margin-top:8px}
@media(max-width:560px){.opts{grid-template-columns:1fr}}
.opt{padding:16px 18px; border-radius:14px; border:1px solid var(--card-brd); background:var(--bg2); cursor:pointer; font-size:16px; font-weight:600; text-align:center; transition:transform .08s,border-color .12s,background .12s}
.opt:hover{transform:translateY(-2px); border-color:var(--primary)}
.opt.correct{background:color-mix(in srgb,var(--good) 22%,transparent); border-color:var(--good)}
.opt.wrong{background:color-mix(in srgb,var(--bad) 22%,transparent); border-color:var(--bad)}
.opt.dim{opacity:.45}

/* ---------- memory match grid ---------- */
.mem-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:12px}
@media(max-width:560px){.mem-grid{grid-template-columns:repeat(3,1fr); gap:8px}}
.mem-card{aspect-ratio:1/1; perspective:900px; cursor:pointer}
.mem-inner{position:relative; width:100%; height:100%; transition:transform .45s; transform-style:preserve-3d}
.mem-card.flip .mem-inner,.mem-card.matched .mem-inner{transform:rotateY(180deg)}
.mem-face{position:absolute; inset:0; display:flex; align-items:center; justify-content:center; border-radius:14px; backface-visibility:hidden; padding:8px; text-align:center; font-weight:700; font-size:15px}
.mem-front{background:linear-gradient(135deg,var(--primary),var(--accent)); color:#fff}
.mem-back{background:var(--bg3); border:1px solid var(--card-brd); transform:rotateY(180deg)}
.mem-card.matched .mem-face{box-shadow:0 0 0 2px var(--good); opacity:.85}

/* ---------- flashcards ---------- */
.flash{max-width:460px; margin:0 auto; perspective:1200px}
.flash-inner{position:relative; height:240px; transition:transform .5s; transform-style:preserve-3d; cursor:pointer}
.flash.flip .flash-inner{transform:rotateY(180deg)}
.flash-face{position:absolute; inset:0; display:flex; align-items:center; justify-content:center; border-radius:20px; backface-visibility:hidden; font-size:30px; font-weight:800; padding:20px; text-align:center}
.flash-front{background:var(--bg2); border:1px solid var(--card-brd)}
.flash-back{background:linear-gradient(135deg,var(--primary),var(--accent)); color:#fff; transform:rotateY(180deg)}

/* ---------- HUD / progress ---------- */
.hud{display:flex; gap:10px; justify-content:center; margin-bottom:18px; flex-wrap:wrap}
.stat2{background:var(--bg2); border:1px solid var(--card-brd); border-radius:12px; padding:8px 16px; font-weight:700; font-size:14px}
.progress{height:8px; background:var(--bg3); border-radius:999px; overflow:hidden; margin-bottom:20px}
.progress>div{height:100%; background:linear-gradient(90deg,var(--primary),var(--accent)); transition:width .3s}
.feedback{text-align:center; font-weight:700; min-height:24px; margin-top:10px}
.feedback.ok{color:var(--good)} .feedback.no{color:var(--bad)}
.speaker{cursor:pointer; font-size:22px; background:var(--bg2); border:1px solid var(--card-brd); border-radius:12px; padding:8px 14px; display:inline-flex}
.speaker:hover{border-color:var(--primary)}
.result{text-align:center; padding:30px}
.result .score{font-size:60px; font-weight:800}

/* ---------- mode picker ---------- */
.mode-card{cursor:pointer; text-align:center; transition:transform .1s,border-color .12s}
.mode-card:hover{transform:translateY(-3px); border-color:var(--primary)}
.mode-card .ico{font-size:32px; margin-bottom:8px}

/* ---------- branding / swatches ---------- */
.logo-upload{display:flex; align-items:center; gap:16px}
.logo-preview{width:84px; height:84px; border-radius:18px; background:var(--bg3); border:1px solid var(--card-brd); display:flex; align-items:center; justify-content:center; font-size:30px; overflow:hidden; flex-shrink:0}
.logo-preview img{width:100%; height:100%; object-fit:cover}
.swatch{width:30px; height:30px; border-radius:9px; cursor:pointer; border:2px solid transparent; display:inline-block; transition:transform .1s}
.swatch:hover{transform:scale(1.12)}
.swatch.sel{border-color:var(--txt); box-shadow:0 0 0 2px var(--bg)}

/* ---------- toast ---------- */
.toast{position:fixed; left:50%; bottom:28px; transform:translateX(-50%) translateY(20px); background:var(--bg3); color:var(--txt); border:1px solid var(--card-brd); padding:13px 22px; border-radius:14px; font-size:14px; font-weight:600; box-shadow:var(--shadow); opacity:0; pointer-events:none; transition:opacity .2s,transform .2s; z-index:99; max-width:90vw}
.toast.show{opacity:1; transform:translateX(-50%) translateY(0)}
.toast.err{border-color:var(--bad); color:#fff; background:linear-gradient(120deg,#b91c1c,#ef4444)}
</file>

