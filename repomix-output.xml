import React, { useState, useEffect } from 'react';
import api from '../utils/api';
import TTSButton from '../components/TTSButton';
import { X, CheckCircle, HelpCircle, ArrowRight, RotateCcw, Award, Check, Sparkles, Volume2 } from 'lucide-react';

export default function GamePlayer({ setId, mode: initialMode, onClose }) {
  const [set, setSet] = useState(null);
  const [words, setWords] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');
  
  // Game states
  const [gameMode, setGameMode] = useState(initialMode);
  const [completed, setCompleted] = useState(false);
  const [score, setScore] = useState(0);

  // 1. FLASHCARDS STATE
  const [currentIdx, setCurrentIdx] = useState(0);
  const [isFlipped, setIsFlipped] = useState(false);

  // 2. MATCHING STATE
  const [cards, setCards] = useState([]);
  const [selectedCards, setSelectedCards] = useState([]); // indices
  const [matchedPairs, setMatchedPairs] = useState([]); // matching word IDs
  const [mismatchedCards, setMismatchedCards] = useState([]); // temporary error states

  // 3. QUIZ STATE
  const [quizQuestionIdx, setQuizQuestionIdx] = useState(0);
  const [quizOptions, setQuizOptions] = useState([]);
  const [selectedOption, setSelectedOption] = useState(null);
  const [answerChecked, setAnswerChecked] = useState(false);

  // 4. SCRAMBLE STATE
  const [scrambleIdx, setScrambleIdx] = useState(0);
  const [scrambleLetters, setScrambleLetters] = useState([]);
  const [scrambleAnswer, setScrambleAnswer] = useState([]);
  const [scrambleChecked, setScrambleChecked] = useState(false);
  const [scrambleSuccess, setScrambleSuccess] = useState(false);

  // 5. TYPE-IN STATE
  const [typeInIdx, setTypeInIdx] = useState(0);
  const [userInput, setUserInput] = useState('');
  const [typeInChecked, setTypeInChecked] = useState(false);
  const [typeInSuccess, setTypeInSuccess] = useState(false);

  const playTTS = (text, lang) => {
    if (!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    let bcp47 = lang || 'es';
    if (bcp47 === 'es') bcp47 = 'es-ES';
    else if (bcp47 === 'ar') bcp47 = 'ar-SA';
    else if (bcp47 === 'en') bcp47 = 'en-US';
    else if (bcp47 === 'fr') bcp47 = 'fr-FR';
    else if (bcp47 === 'de') bcp47 = 'de-DE';
    else if (bcp47 === 'it') bcp47 = 'it-IT';

    utterance.lang = bcp47;
    utterance.rate = 0.85;

    const voices = window.speechSynthesis.getVoices();
    const voiceMatch = voices.find(v => v.lang.startsWith(lang) || v.lang === bcp47);
    if (voiceMatch) {
      utterance.voice = voiceMatch;
    }

    window.speechSynthesis.speak(utterance);
  };

  // Auto-play text-to-speech in listening mode
  useEffect(() => {
    if (gameMode === 'listening' && words.length > 0 && quizQuestionIdx < words.length && !loading) {
      const term = words[quizQuestionIdx]?.term;
      if (term) {
        const timer = setTimeout(() => {
          playTTS(term, set?.target_lang);
        }, 350);
        return () => clearTimeout(timer);
      }
    }
  }, [quizQuestionIdx, gameMode, words, loading, set]);

  // Fetch word set on mount
  useEffect(() => {
    const fetchSet = async () => {
      try {
        setLoading(true);
        const data = await api.get(`/sets/${setId}`);
        setSet(data);
        setWords(data.words);
        initializeGame(gameMode, data.words);
      } catch (err) {
        setError(err.message || 'Failed to load vocabulary set.');
      } finally {
        setLoading(false);
      }
    };
    fetchSet();
  }, [setId]);

  // Setup game board variables
  const initializeGame = (mode, wordList) => {
    setCompleted(false);
    setScore(0);
    
    if (wordList.length === 0) return;

    if (mode === 'flashcards') {
      setCurrentIdx(0);
      setIsFlipped(false);
    } 
    else if (mode === 'matching') {
      // Create memory cards (term cards + translation cards)
      const termCards = wordList.map(w => ({
        id: `term-${w.id}`,
        wordId: w.id,
        text: w.term,
        type: 'term',
        lang: 'target'
      }));
      
      const translationCards = wordList.map(w => ({
        id: `trans-${w.id}`,
        wordId: w.id,
        text: w.translation,
        type: 'translation',
        lang: 'source'
      }));

      // Merge and Shuffle
      const merged = [...termCards, ...translationCards].sort(() => Math.random() - 0.5);
      setCards(merged);
      setSelectedCards([]);
      setMatchedPairs([]);
      setMismatchedCards([]);
    } 
    else if (mode === 'quiz' || mode === 'listening') {
      setQuizQuestionIdx(0);
      generateQuizOptions(0, wordList);
    }
    else if (mode === 'scramble') {
      setScrambleIdx(0);
      generateScramble(0, wordList);
    }
    else if (mode === 'typein') {
      setTypeInIdx(0);
      setUserInput('');
      setTypeInChecked(false);
      setTypeInSuccess(false);
    }
  };

  // -------------------------
  // FLASHCARD ACTIONS
  // -------------------------
  const nextFlashcard = () => {
    setIsFlipped(false);
    setTimeout(() => {
      if (currentIdx < words.length - 1) {
        setCurrentIdx(currentIdx + 1);
      } else {
        // Automatically completes flashcards
        finishSession(words.length);
      }
    }, 150);
  };

  const prevFlashcard = () => {
    setIsFlipped(false);
    setTimeout(() => {
      if (currentIdx > 0) {
        setCurrentIdx(currentIdx - 1);
      }
    }, 150);
  };

  // -------------------------
  // MATCHING GAME ACTIONS
  // -------------------------
  const handleCardClick = (idx) => {
    const card = cards[idx];
    
    // Ignore already matched or already selected cards
    if (matchedPairs.includes(card.wordId) || selectedCards.includes(idx) || selectedCards.length >= 2) {
      return;
    }

    const newSelected = [...selectedCards, idx];
    setSelectedCards(newSelected);

    if (newSelected.length === 2) {
      const first = cards[newSelected[0]];
      const second = cards[newSelected[1]];

      if (first.wordId === second.wordId && first.type !== second.type) {
        // MATCH SUCCESS
        setTimeout(() => {
          const newMatches = [...matchedPairs, first.wordId];
          setMatchedPairs(newMatches);
          setSelectedCards([]);
          setScore(prev => prev + 1);

          // Win Check
          if (newMatches.length === words.length) {
            finishSession(words.length);
          }
        }, 300);
      } else {
        // MISMATCH
        setTimeout(() => {
          setMismatchedCards(newSelected);
          setTimeout(() => {
            setSelectedCards([]);
            setMismatchedCards([]);
          }, 800);
        }, 300);
      }
    }
  };

  // -------------------------
  // QUIZ GAME ACTIONS
  // -------------------------
  const generateQuizOptions = (idx, wordList) => {
    if (idx >= wordList.length) return;
    const correct = wordList[idx];
    
    // Pick 3 incorrect options from other words
    const others = wordList.filter(w => w.id !== correct.id);
    const shuffledOthers = others.sort(() => Math.random() - 0.5);
    const wrongOptions = shuffledOthers.slice(0, 3).map(w => w.translation);

    // Merge options
    const options = [correct.translation, ...wrongOptions].sort(() => Math.random() - 0.5);
    
    // If set is very small, pad choices
    while (options.length < 4) {
      options.push('Filler Option ' + (options.length + 1));
    }

    setQuizOptions(options);
    setSelectedOption(null);
    setAnswerChecked(false);
  };

  const handleSelectQuizOption = (opt) => {
    if (answerChecked) return;
    setSelectedOption(opt);
  };

  const checkQuizAnswer = () => {
    if (selectedOption === null || answerChecked) return;
    const correct = words[quizQuestionIdx];
    const isCorrect = selectedOption === correct.translation;

    if (isCorrect) {
      setScore(prev => prev + 1);
    }
    setAnswerChecked(true);
  };

  const nextQuizQuestion = () => {
    if (quizQuestionIdx < words.length - 1) {
      const nextIdx = quizQuestionIdx + 1;
      setQuizQuestionIdx(nextIdx);
      generateQuizOptions(nextIdx, words);
    } else {
      finishSession(score);
    }
  };

  // -------------------------
  // WORD SCRAMBLE ACTIONS
  // -------------------------
  const generateScramble = (idx, wordList) => {
    if (idx >= wordList.length) return;
    const targetWord = wordList[idx].term;

    // Scramble letters
    const letters = targetWord.split('').map((char, index) => ({
      id: `${char}-${index}`,
      char,
      used: false
    }));
    
    const scrambled = [...letters].sort(() => Math.random() - 0.5);
    setScrambleLetters(scrambled);
    setScrambleAnswer([]);
    setScrambleChecked(false);
    setScrambleSuccess(false);
  };

  const handleLetterClick = (letterObj, isFromAnswer) => {
    if (scrambleChecked) return;

    if (isFromAnswer) {
      // Remove from answer, mark unused in source
      setScrambleAnswer(scrambleAnswer.filter(l => l.id !== letterObj.id));
      setScrambleLetters(scrambleLetters.map(l => l.id === letterObj.id ? { ...l, used: false } : l));
    } else {
      // Add to answer, mark used in source
      setScrambleAnswer([...scrambleAnswer, letterObj]);
      setScrambleLetters(scrambleLetters.map(l => l.id === letterObj.id ? { ...l, used: true } : l));
    }
  };

  const checkScrambleAnswer = () => {
    if (scrambleChecked) return;
    const finalAnswer = scrambleAnswer.map(l => l.char).join('');
    const correct = words[scrambleIdx].term;
    const isCorrect = finalAnswer === correct;

    setScrambleSuccess(isCorrect);
    if (isCorrect) {
      setScore(prev => prev + 1);
    }
    setScrambleChecked(true);
  };

  const nextScrambleQuestion = () => {
    if (scrambleIdx < words.length - 1) {
      const nextIdx = scrambleIdx + 1;
      setScrambleIdx(nextIdx);
      generateScramble(nextIdx, words);
    } else {
      finishSession(score);
    }
  };

  // -------------------------
  // TYPE-IN ACTIONS
  // -------------------------
  const checkTypeInAnswer = () => {
    if (typeInChecked) return;
    const cleanInput = userInput.trim().toLowerCase();
    const correct = words[typeInIdx].term.trim().toLowerCase();
    const isCorrect = cleanInput === correct;

    setTypeInSuccess(isCorrect);
    if (isCorrect) {
      setScore(prev => prev + 1);
    }
    setTypeInChecked(true);
  };

  const nextTypeInQuestion = () => {
    if (typeInIdx < words.length - 1) {
      const nextIdx = typeInIdx + 1;
      setTypeInIdx(nextIdx);
      setUserInput('');
      setTypeInChecked(false);
      setTypeInSuccess(false);
    } else {
      finishSession(score);
    }
  };

  // -------------------------
  // FINISH GAME & LOG STATS
  // -------------------------
  const finishSession = async (finalScore) => {
    setCompleted(true);
    
    // Only students post progress metrics to the platform database!
    if (api.getToken()) {
      const decodedUser = JSON.parse(atob(api.getToken().split('.')[1]));
      if (decodedUser && decodedUser.role === 'student') {
        try {
          console.log(`Saving game logs: Mode=${gameMode}, Score=${finalScore}/${words.length}`);
          await api.post(`/sets/${setId}/progress`, {
            gameMode,
            score: finalScore,
            totalWords: words.length
          });
        } catch (e) {
          console.error('Failed to log student session statistics:', e);
        }
      }
    }
  };

  if (loading) {
    return (
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100vh', background: 'var(--bg-main)' }}>
        <p>Loading game board...</p>
      </div>
    );
  }

  if (error) {
    return (
      <div style={{ padding: '40px', textAlign: 'center' }}>
        <h2>Error Launching Game</h2>
        <p style={{ color: 'var(--color-error)', margin: '15px 0' }}>{error}</p>
        <button onClick={onClose} className="action-button-secondary">Return to Dashboard</button>
      </div>
    );
  }

  const isRtl = set.target_lang === 'ar';

  return (
    <div 
      style={{ 
        position: 'fixed', 
        inset: 0, 
        background: 'var(--bg-main)', 
        zIndex: 100, 
        display: 'flex', 
        flexDirection: 'column',
        fontFamily: 'Plus Jakarta Sans, sans-serif'
      }}
    >
      {/* Game Header */}
      <header 
        style={{ 
          padding: '15px 30px', 
          background: 'var(--bg-card)', 
          borderBottom: '1px solid var(--border-color)', 
          display: 'flex', 
          alignItems: 'center', 
          justifyContent: 'space-between' 
        }}
      >
        <div>
          <span 
            style={{ 
              fontSize: '11px', 
              fontWeight: '700', 
              textTransform: 'uppercase', 
              background: 'var(--primary-glow)', 
              color: 'var(--primary-color)', 
              padding: '3px 8px', 
              borderRadius: '4px',
              marginRight: '10px'
            }}
          >
            {gameMode} mode
          </span>
          <strong style={{ fontSize: '18px', fontFamily: 'Outfit' }}>{set.title}</strong>
        </div>
        
        <button 
          onClick={onClose}
          style={{ 
            background: 'transparent', 
            border: 'none', 
            cursor: 'pointer', 
            color: 'var(--text-muted)',
            padding: '5px',
            borderRadius: '6px',
            hover: { background: 'var(--border-color)' }
          }}
        >
          <X size={22} />
        </button>
      </header>

      {/* Main Game Screen */}
      <div style={{ flex: 1, overflowY: 'auto', display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '40px' }}>
        
        {/* VIEW A: COMPLETED SCREEN */}
        {completed ? (
          <div className="card-item animate-scale" style={{ maxWidth: '450px', width: '100%', padding: '40px', textPosition: 'center', textAlign: 'center' }}>
            <Award size={64} style={{ color: '#F59E0B', margin: '0 auto 20px' }} />
            <h2 style={{ fontSize: '26px', marginBottom: '10px' }}>Well Done!</h2>
            <p className="text-muted" style={{ marginBottom: '25px' }}>You have completed the vocabulary review.</p>
            
            {gameMode !== 'flashcards' && (
              <div style={{ background: 'var(--bg-main)', padding: '20px', borderRadius: '10px', marginBottom: '30px' }}>
                <div style={{ fontSize: '14px', color: 'var(--text-muted)', marginBottom: '5px' }}>Score card Accuracy</div>
                <div style={{ fontSize: '36px', fontWeight: '800', color: 'var(--primary-color)' }}>
                  {Math.round((score / words.length) * 100)}%
                </div>
                <div style={{ fontSize: '14px', fontWeight: '600', marginTop: '5px' }}>
                  ({score} correct out of {words.length})
                </div>
              </div>
            )}

            <div style={{ display: 'flex', gap: '15px' }}>
              <button 
                onClick={() => initializeGame(gameMode, words)} 
                className="action-button-secondary"
                style={{ flex: 1 }}
              >
                <RotateCcw size={16} style={{ marginRight: '6px' }} />
                Play Again
              </button>
              <button 
                onClick={onClose} 
                className="action-button-primary"
                style={{ flex: 1 }}
              >
                Finish Session
              </button>
            </div>
          </div>
        ) : (
          
          /* GAME PLAY VIEWS */
          <div style={{ maxWidth: '650px', width: '100%' }}>
            
            {/* VIEW B: FLASHCARDS BOARD */}
            {gameMode === 'flashcards' && (
              <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '30px' }}>
                <div 
                  onClick={() => setIsFlipped(!isFlipped)}
                  className={`memory-card ${isFlipped ? 'flipped' : ''}`}
                  style={{ width: '300px', height: '380px' }}
                >
                  <div className="card-inner">
                    <div className="card-front" style={{ fontSize: '24px', display: 'flex', flexDirection: 'column', gap: '15px' }}>
                      <span style={{ fontSize: '12px', opacity: 0.7 }}>Vocabulary Term</span>
                      <div dir={isRtl ? 'rtl' : 'ltr'}>{words[currentIdx].term}</div>
                      <TTSButton text={words[currentIdx].term} lang={set.target_lang} />
                    </div>
                    <div className="card-back" style={{ fontSize: '20px', display: 'flex', flexDirection: 'column', gap: '12px', justifyContent: 'center' }}>
                      <span style={{ fontSize: '11px', color: 'var(--text-muted)', textTransform: 'uppercase' }}>Translation</span>
                      <div style={{ fontWeight: '700' }}>{words[currentIdx].translation}</div>
                      {words[currentIdx].hint && (
                        <div style={{ fontSize: '13px', color: 'var(--text-muted)', borderTop: '1px solid var(--border-color)', marginTop: '15px', paddingTop: '10px', fontStyle: 'italic' }}>
                          Hint: {words[currentIdx].hint}
                        </div>
                      )}
                    </div>
                  </div>
                </div>

                <div style={{ display: 'flex', alignItems: 'center', gap: '20px' }}>
                  <button 
                    onClick={prevFlashcard} 
                    className="action-button-secondary" 
                    disabled={currentIdx === 0}
                  >
                    Previous
                  </button>
                  <span style={{ fontWeight: '600' }}>{currentIdx + 1} / {words.length}</span>
                  <button 
                    onClick={nextFlashcard} 
                    className="action-button-primary"
                  >
                    {currentIdx === words.length - 1 ? 'Finish' : 'Next Card'}
                  </button>
                </div>
              </div>
            )}

            {/* VIEW C: MEMORY CARD MATCHING BOARD */}
            {gameMode === 'matching' && (
              <div>
                <div style={{ display: 'flex', justifySelf: 'stretch', justifyContent: 'space-between', marginBottom: '20px', fontSize: '14px', fontWeight: '600' }}>
                  <span>Matched Pairs: {matchedPairs.length} / {words.length}</span>
                  <span>Select two matching cards</span>
                </div>
                
                <div className="game-grid">
                  {cards.map((card, idx) => {
                    const isSelected = selectedCards.includes(idx);
                    const isMatched = matchedPairs.includes(card.wordId);
                    const isMismatched = mismatchedCards.includes(idx);
                    
                    return (
                      <div 
                        key={card.id}
                        onClick={() => handleCardClick(idx)}
                        className={`memory-card ${isSelected || isMatched ? 'flipped' : ''} ${isMatched ? 'matched' : ''} ${isMismatched ? 'mismatched' : ''}`}
                      >
                        <div className="card-inner">
                          <div className="card-front" />
                          <div className="card-back" style={{ borderColor: isSelected ? 'var(--primary-color)' : 'var(--border-color)' }}>
                            <div 
                              dir={card.lang === 'target' && isRtl ? 'rtl' : 'ltr'}
                              style={{ fontSize: '14px', fontWeight: '600' }}
                            >
                              {card.text}
                            </div>
                            {card.type === 'term' && (
                              <div style={{ position: 'absolute', bottom: '6px', right: '6px' }}>
                                <TTSButton text={card.text} lang={set.target_lang} />
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            {/* VIEW D: MCQ QUIZ & LISTENING BOARD */}
            {(gameMode === 'quiz' || gameMode === 'listening') && (
              <div className="card-item" style={{ padding: '30px' }}>
                <div style={{ display: 'flex', justifySelf: 'stretch', justifyContent: 'space-between', marginBottom: '20px', fontSize: '13px', color: 'var(--text-muted)' }}>
                  <span>Question {quizQuestionIdx + 1} of {words.length}</span>
                  <span>Accuracy Score: {score}</span>
                </div>

                <div style={{ textAlign: 'center', marginBottom: '30px' }}>
                  {gameMode === 'quiz' ? (
                    <>
                      <div style={{ fontSize: '12px', color: 'var(--text-muted)', textTransform: 'uppercase', marginBottom: '5px' }}>Find the translation of:</div>
                      <h2 dir={isRtl ? 'rtl' : 'ltr'} style={{ fontSize: '28px', color: 'var(--primary-color)', marginBottom: '10px' }}>
                        {words[quizQuestionIdx].term}
                      </h2>
                      <TTSButton text={words[quizQuestionIdx].term} lang={set.target_lang} />
                    </>
                  ) : (
                    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', margin: '10px 0' }}>
                      <div style={{ fontSize: '12px', color: 'var(--text-muted)', textTransform: 'uppercase', marginBottom: '15px' }}>Listen to the word and select translation:</div>
                      <button 
                        type="button"
                        onClick={() => playTTS(words[quizQuestionIdx].term, set.target_lang)}
                        className="listening-speaker-pulse-card animate-pulse"
                        style={{ 
                          width: '90px', 
                          height: '90px', 
                          borderRadius: '50%', 
                          background: 'var(--primary-glow)', 
                          border: '2px solid var(--primary-color)',
                          color: 'var(--primary-color)',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center',
                          cursor: 'pointer',
                          boxShadow: '0 0 15px var(--primary-glow)',
                          transition: 'transform 0.15s ease',
                          outline: 'none'
                        }}
                        onMouseDown={(e) => e.currentTarget.style.transform = 'scale(0.95)'}
                        onMouseUp={(e) => e.currentTarget.style.transform = 'scale(1)'}
                      >
                        <Volume2 size={36} />
                      </button>
                      <span style={{ fontSize: '12px', color: 'var(--text-muted)', marginTop: '10px', fontWeight: '600' }}>
                        Click to play audio
                      </span>
                      
                      {/* Reveal target spelling when checked */}
                      {answerChecked && (
                        <div style={{ marginTop: '20px', animation: 'fadeIn 0.25s ease' }}>
                          <div style={{ fontSize: '11px', color: 'var(--text-muted)', textTransform: 'uppercase', marginBottom: '2px' }}>Spelling:</div>
                          <h3 dir={isRtl ? 'rtl' : 'ltr'} style={{ fontSize: '24px', color: 'var(--primary-color)' }}>
                            {words[quizQuestionIdx].term}
                          </h3>
                        </div>
                      )}
                    </div>
                  )}
                  
                  {words[quizQuestionIdx].hint && (
                    <p style={{ fontSize: '13px', fontStyle: 'italic', color: 'var(--text-muted)', marginTop: '12px' }}>
                      Clue: {words[quizQuestionIdx].hint}
                    </p>
                  )}
                </div>

                {/* Option choices */}
                <div style={{ display: 'flex', flexDirection: 'column', gap: '12px', marginBottom: '25px' }}>
                  {quizOptions.map((opt, idx) => {
                    const isSelected = selectedOption === opt;
                    const isCorrect = opt === words[quizQuestionIdx].translation;
                    
                    let bg = 'var(--bg-card)';
                    let border = '1px solid var(--border-color)';
                    
                    if (answerChecked) {
                      if (isCorrect) {
                        bg = 'rgba(16, 185, 129, 0.12)';
                        border = '2px solid #10B981';
                      } else if (isSelected) {
                        bg = 'rgba(239, 68, 68, 0.12)';
                        border = '2px solid #EF4444';
                      }
                    } else if (isSelected) {
                      border = '2px solid var(--primary-color)';
                      bg = 'var(--primary-glow)';
                    }

                    return (
                      <button
                        key={idx}
                        onClick={() => handleSelectQuizOption(opt)}
                        style={{ 
                          width: '100%', 
                          padding: '14px 20px', 
                          background: bg,
                          border: border,
                          borderRadius: '8px', 
                          fontWeight: '600', 
                          fontSize: '15px', 
                          cursor: answerChecked ? 'default' : 'pointer',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'space-between',
                          textAlign: 'left'
                        }}
                      >
                        <span>{opt}</span>
                        {answerChecked && isCorrect && <Check size={18} style={{ color: '#10B981' }} />}
                      </button>
                    );
                  })}
                </div>

                {/* Action button */}
                {!answerChecked ? (
                  <button
                    onClick={checkQuizAnswer}
                    className="action-button-primary"
                    style={{ width: '100%' }}
                    disabled={selectedOption === null}
                  >
                    Check Answer
                  </button>
                ) : (
                  <button
                    onClick={nextQuizQuestion}
                    className="action-button-primary"
                    style={{ width: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '8px' }}
                  >
                    <span>{quizQuestionIdx === words.length - 1 ? 'Finish' : 'Next Question'}</span>
                    <ArrowRight size={16} />
                  </button>
                )}
              </div>
            )}

            {/* VIEW E: WORD SCRAMBLE BOARD */}
            {gameMode === 'scramble' && (
              <div className="card-item" style={{ padding: '30px' }}>
                <div style={{ display: 'flex', justifySelf: 'stretch', justifyContent: 'space-between', marginBottom: '20px', fontSize: '13px', color: 'var(--text-muted)' }}>
                  <span>Scramble {scrambleIdx + 1} of {words.length}</span>
                  <span>Accuracy Score: {score}</span>
                </div>

                <div style={{ textAlign: 'center', marginBottom: '25px' }}>
                  <div style={{ fontSize: '12px', color: 'var(--text-muted)', textTransform: 'uppercase', marginBottom: '5px' }}>Assemble this word:</div>
                  <h2 style={{ fontSize: '24px', color: 'var(--primary-color)', marginBottom: '10px' }}>
                    {words[scrambleIdx].translation}
                  </h2>
                  {words[scrambleIdx].hint && (
                    <p style={{ fontSize: '13px', color: 'var(--text-muted)' }}>Hint: {words[scrambleIdx].hint}</p>
                  )}
                </div>

                {/* Answer assembly Area */}
                <div 
                  style={{ 
                    minHeight: '60px', 
                    border: scrambleChecked 
                      ? scrambleSuccess ? '2px solid #10B981' : '2px solid #EF4444'
                      : '2px dashed var(--border-color)', 
                    borderRadius: '8px',
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    gap: '8px',
                    padding: '10px',
                    marginBottom: '25px',
                    background: scrambleChecked 
                      ? scrambleSuccess ? 'rgba(16, 185, 129, 0.05)' : 'rgba(239, 68, 68, 0.05)'
                      : 'var(--bg-main)'
                  }}
                >
                  {scrambleAnswer.map((l, idx) => (
                    <button
                      key={idx}
                      onClick={() => handleLetterClick(l, true)}
                      disabled={scrambleChecked}
                      style={{ 
                        padding: '10px 14px', 
                        background: 'var(--bg-card)', 
                        border: '1px solid var(--border-color)', 
                        borderRadius: '6px', 
                        fontWeight: '700', 
                        fontSize: '16px',
                        cursor: 'pointer'
                      }}
                    >
                      {l.char}
                    </button>
                  ))}
                  {scrambleAnswer.length === 0 && <span style={{ color: 'var(--text-muted)', fontSize: '13px' }}>Click letters to assemble word</span>}
                </div>

                {/* Scramble selection letters */}
                <div style={{ display: 'flex', flexWrap: 'wrap', justifyContent: 'center', gap: '8px', marginBottom: '30px' }}>
                  {scrambleLetters.map((l) => (
                    <button
                      key={l.id}
                      onClick={() => handleLetterClick(l, false)}
                      disabled={l.used || scrambleChecked}
                      style={{ 
                        padding: '10px 14px', 
                        background: 'var(--bg-card)', 
                        border: '1px solid var(--border-color)', 
                        borderRadius: '6px', 
                        fontWeight: '700', 
                        fontSize: '16px',
                        cursor: 'pointer',
                        opacity: l.used ? 0.25 : 1,
                        transition: 'opacity 0.1s ease'
                      }}
                    >
                      {l.char}
                    </button>
                  ))}
                </div>

                {/* Action controls */}
                {!scrambleChecked ? (
                  <button
                    onClick={checkScrambleAnswer}
                    className="action-button-primary"
                    style={{ width: '100%' }}
                    disabled={scrambleAnswer.length === 0}
                  >
                    Check Spelling
                  </button>
                ) : (
                  <div>
                    {!scrambleSuccess && (
                      <div style={{ color: '#EF4444', textAlign: 'center', fontSize: '14px', fontWeight: '600', marginBottom: '15px' }}>
                        Incorrect answer. Correct spelling: <strong style={{ fontSize: '16px' }}>{words[scrambleIdx].term}</strong>
                      </div>
                    )}
                    <button
                      onClick={nextScrambleQuestion}
                      className="action-button-primary"
                      style={{ width: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '8px' }}
                    >
                      <span>{scrambleIdx === words.length - 1 ? 'Finish' : 'Next Word'}</span>
                      <ArrowRight size={16} />
                    </button>
                  </div>
                )}
              </div>
            )}

            {/* VIEW F: TYPE-IN BOARD */}
            {gameMode === 'typein' && (
              <div className="card-item" style={{ padding: '30px' }}>
                <div style={{ display: 'flex', justifySelf: 'stretch', justifyContent: 'space-between', marginBottom: '20px', fontSize: '13px', color: 'var(--text-muted)' }}>
                  <span>Speller {typeInIdx + 1} of {words.length}</span>
                  <span>Accuracy Score: {score}</span>
                </div>

                <div style={{ textAlign: 'center', marginBottom: '25px' }}>
                  <div style={{ fontSize: '12px', color: 'var(--text-muted)', textTransform: 'uppercase', marginBottom: '5px' }}>Write in the learned target language:</div>
                  <h2 style={{ fontSize: '24px', color: 'var(--primary-color)', marginBottom: '10px' }}>
                    {words[typeInIdx].translation}
                  </h2>
                  {words[typeInIdx].hint && (
                    <p style={{ fontSize: '13px', color: 'var(--text-muted)' }}>Hint: {words[typeInIdx].hint}</p>
                  )}
                </div>

                {/* Input Textbox */}
                <div style={{ marginBottom: '25px' }}>
                  <input
                    type="text"
                    placeholder="Type translation spelling..."
                    value={userInput}
                    onChange={(e) => setUserInput(e.target.value)}
                    disabled={typeInChecked}
                    className="form-input-control"
                    style={{ 
                      textAlign: 'center', 
                      fontSize: '18px', 
                      fontWeight: '600', 
                      height: '50px',
                      border: typeInChecked
                        ? typeInSuccess ? '2px solid #10B981' : '2px solid #EF4444'
                        : '1px solid var(--border-color)',
                      background: typeInChecked 
                        ? typeInSuccess ? 'rgba(16, 185, 129, 0.05)' : 'rgba(239, 68, 68, 0.05)'
                        : 'var(--bg-card)'
                    }}
                    onKeyDown={(e) => {
                      if (e.key === 'Enter' && userInput.trim() && !typeInChecked) {
                        checkTypeInAnswer();
                      }
                    }}
                    required
                  />
                </div>

                {/* Action button */}
                {!typeInChecked ? (
                  <button
                    onClick={checkTypeInAnswer}
                    className="action-button-primary"
                    style={{ width: '100%' }}
                    disabled={!userInput.trim()}
                  >
                    Submit Answer
                  </button>
                ) : (
                  <div>
                    {!typeInSuccess && (
                      <div style={{ color: '#EF4444', textAlign: 'center', fontSize: '14px', fontWeight: '600', marginBottom: '15px' }}>
                        Incorrect spelling. Correct answer: <strong style={{ fontSize: '16px' }}>{words[typeInIdx].term}</strong>
                      </div>
                    )}
                    <button
                      onClick={nextTypeInQuestion}
                      className="action-button-primary"
                      style={{ width: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '8px' }}
                    >
                      <span>{typeInIdx === words.length - 1 ? 'Finish' : 'Next Word'}</span>
                      <ArrowRight size={16} />
                    </button>
                  </div>
                )}
              </div>
            )}

          </div>
        )}
      </div>
    </div>
  );
}
</file>

<file path="frontend/src/pages/Login.jsx">
import React, { useState, useEffect } from 'react';
import api from '../utils/api';
import { Mail, Lock, Shield, GraduationCap, ArrowRight } from 'lucide-react';

export default function Login({ onLoginSuccess, onSwitchToRegister }) {
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  
  // Custom Tenant Configuration (visual skinning)
  const [tenantSlug, setTenantSlug] = useState(localStorage.getItem('edumatch_tenant_slug') || '');
  const [tenantConfig, setTenantConfig] = useState(null);

  useEffect(() => {
    if (tenantSlug) {
      api.get(`/auth/tenant/${tenantSlug}`)
        .then(data => {
          setTenantConfig(data);
          localStorage.setItem('edumatch_tenant_slug', tenantSlug);
        })
        .catch(() => {
          console.warn('Invalid tenant slug saved, cleaning up.');
          setTenantConfig(null);
        });
    }
  }, [tenantSlug]);

  const handleSubmit = async (e) => {
    e.preventDefault();
    setError('');
    
    if (!email || !password) {
      setError('Please fill in all credentials.');
      return;
    }

    setLoading(true);
    try {
      const data = await api.post('/auth/login', { email, password });
      onLoginSuccess(data.token, data.user, data.organization);
    } catch (err) {
      setError(err.message || 'Login failed. Please check your credentials.');
    } finally {
      setLoading(false);
    }
  };

  const handleClearTenant = () => {
    localStorage.removeItem('edumatch_tenant_slug');
    setTenantSlug('');
    setTenantConfig(null);
    // Reload styles back to default
    const root = document.documentElement;
    root.style.setProperty('--primary-color', '#4F46E5');
    root.style.setProperty('--secondary-color', '#818CF8');
    document.body.classList.remove('dark');
  };

  return (
    <div className="login-page-container">
      {/* Background blobs for premium depth styling */}
      <div className="bg-blob-1" />
      <div className="bg-blob-2" />

      <div className="login-card-wrapper glassmorphism">
        
        {/* Brand Header */}
        <div className="login-header">
          {tenantConfig && tenantConfig.logo_data ? (
            <img src={tenantConfig.logo_data} alt={tenantConfig.name} className="login-tenant-logo" />
          ) : (
            <div className="login-logo-fallback animate-scale">
              <GraduationCap size={40} style={{ color: 'var(--primary-color)' }} />
            </div>
          )}
          
          <h2 className="login-title">
            {tenantConfig ? `Welcome to ${tenantConfig.name}` : 'Sign In to EduMatch'}
          </h2>
          <p className="login-subtitle">
            {tenantConfig 
              ? 'Vocabulary lessons and matching games' 
              : 'The multi-tenant language-education platform'
            }
          </p>
        </div>

        {/* Error Notification */}
        {error && (
          <div className="login-error-card animate-scale">
            <Shield size={16} />
            <span>{error}</span>
          </div>
        )}

        {/* Login Form */}
        <form onSubmit={handleSubmit} className="login-form">
          <div className="login-input-group">
            <label htmlFor="email">Email Address</label>
            <div className="input-with-icon">
              <Mail size={18} className="input-icon" />
              <input
                id="email"
                type="email"
                placeholder="teacher@academy.com or student@vivid.com"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
            </div>
          </div>

          <div className="login-input-group">
            <label htmlFor="password">Password</label>
            <div className="input-with-icon">
              <Lock size={18} className="input-icon" />
              <input
                id="password"
                type="password"
                placeholder="••••••••"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
            </div>
          </div>

          <button 
            type="submit" 
            className="login-submit-btn" 
            disabled={loading}
            style={{ backgroundColor: 'var(--primary-color)' }}
          >
            {loading ? 'Authenticating...' : 'Sign In'}
            {!loading && <ArrowRight size={18} style={{ marginLeft: '8px' }} />}
          </button>
        </form>

        {/* Tenant Details / Footer Link */}
        <div className="login-footer">
          {tenantConfig ? (
            <button onClick={handleClearTenant} className="login-text-link">
              ← Log in to general portal
            </button>
          ) : (
            <>
              <p>Looking for your custom school login? Enter organization slug:</p>
              <div className="tenant-slug-selector" style={{ marginTop: '8px', display: 'flex', gap: '8px' }}>
                <input 
                  type="text" 
                  placeholder="vivid-academy" 
                  className="tenant-slug-input"
                  id="tenant-search"
                  onKeyDown={(e) => {
                    if (e.key === 'Enter') {
                      setTenantSlug(e.target.value);
                    }
                  }}
                />
                <button 
                  onClick={() => {
                    const input = document.getElementById('tenant-search');
                    if (input && input.value) setTenantSlug(input.value);
                  }}
                  className="tenant-slug-btn"
                >
                  Go
                </button>
              </div>
              
              <div style={{ marginTop: '24px', borderTop: '1px solid var(--border-color)', paddingTop: '15px' }}>
                <p>New to EduMatch? <button onClick={onSwitchToRegister} className="login-text-link">Register your organization</button></p>
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  );
}
</file>

<file path="frontend/src/pages/Register.jsx">
import React, { useState } from 'react';
import api from '../utils/api';
import { Mail, Lock, User, Building, Landmark, ArrowRight, Shield } from 'lucide-react';

export default function Register({ onRegisterSuccess, onSwitchToLogin }) {
  const [orgName, setOrgName] = useState('');
  const [orgSlug, setOrgSlug] = useState('');
  const [name, setName] = useState('');
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');

  // Automatically generate clean URL slugs as they type their org name
  const handleOrgNameChange = (e) => {
    const val = e.target.value;
    setOrgName(val);
    
    // Sluggify
    const slug = val
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-') // Replace non-alphanumeric characters with hyphens
      .replace(/(^-|-$)+/g, '');   // Trim leading/trailing hyphens
    
    setOrgSlug(slug);
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setError('');

    if (!orgName || !orgSlug || !name || !email || !password) {
      setError('Please fill in all fields.');
      return;
    }

    setLoading(true);
    try {
      const data = await api.post('/auth/register', {
        orgName,
        orgSlug,
        name,
        email,
        password
      });
      onRegisterSuccess(data.token, data.user, data.organization);
    } catch (err) {
      setError(err.message || 'Registration failed. Try a different email or organization slug.');
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="login-page-container">
      <div className="bg-blob-1" />
      <div className="bg-blob-2" />

      <div className="login-card-wrapper glassmorphism" style={{ maxWidth: '500px' }}>
        
        {/* Header */}
        <div className="login-header" style={{ marginBottom: '25px' }}>
          <div className="login-logo-fallback animate-scale">
            <Building size={40} style={{ color: 'var(--primary-color)' }} />
          </div>
          <h2 className="login-title">Register Your School</h2>
          <p className="login-subtitle">Create your branded language education portal in seconds</p>
        </div>

        {/* Error Notification */}
        {error && (
          <div className="login-error-card animate-scale" style={{ marginBottom: '20px' }}>
            <Shield size={16} />
            <span>{error}</span>
          </div>
        )}

        {/* Registration Form */}
        <form onSubmit={handleSubmit} className="login-form">
          <div className="login-input-group">
            <label htmlFor="orgName">Organization / School Name</label>
            <div className="input-with-icon">
              <Building size={18} className="input-icon" />
              <input
                id="orgName"
                type="text"
                placeholder="e.g. Vivid Language Academy"
                value={orgName}
                onChange={handleOrgNameChange}
                required
              />
            </div>
          </div>

          <div className="login-input-group">
            <label htmlFor="orgSlug">Portal URL Identifier (Slug)</label>
            <div className="input-with-icon">
              <Landmark size={18} className="input-icon" />
              <input
                id="orgSlug"
                type="text"
                placeholder="e.g. vivid-academy"
                value={orgSlug}
                onChange={(e) => setOrgSlug(e.target.value.toLowerCase().replace(/[^a-z0-9-]/g, ''))}
                required
              />
            </div>
            <p className="input-helper-text" style={{ fontSize: '11px', marginTop: '4px', color: 'var(--text-muted)' }}>
              Your portal will be skinned at: <strong>?tenant={orgSlug || 'your-slug'}</strong>
            </p>
          </div>

          <div className="login-input-group">
            <label htmlFor="name">Teacher Name</label>
            <div className="input-with-icon">
              <User size={18} className="input-icon" />
              <input
                id="name"
                type="text"
                placeholder="e.g. Professor Smith"
                value={name}
                onChange={(e) => setName(e.target.value)}
                required
              />
            </div>
          </div>

          <div className="login-input-group">
            <label htmlFor="email">Work Email</label>
            <div className="input-with-icon">
              <Mail size={18} className="input-icon" />
              <input
                id="email"
                type="email"
                placeholder="smith@academy.com"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
            </div>
          </div>

          <div className="login-input-group">
            <label htmlFor="password">Create Password</label>
            <div className="input-with-icon">
              <Lock size={18} className="input-icon" />
              <input
                id="password"
                type="password"
                placeholder="Minimum 6 characters"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
            </div>
          </div>

          <button 
            type="submit" 
            className="login-submit-btn" 
            disabled={loading}
            style={{ backgroundColor: 'var(--primary-color)' }}
          >
            {loading ? 'Registering School...' : 'Create Account'}
            {!loading && <ArrowRight size={18} style={{ marginLeft: '8px' }} />}
          </button>
        </form>

        <div className="login-footer" style={{ marginTop: '20px', paddingTop: '15px', borderTop: '1px solid var(--border-color)' }}>
          <p>Already have an account? <button onClick={onSwitchToLogin} className="login-text-link">Sign In</button></p>
        </div>
      </div>
    </div>
  );
}
