# Server Port
PORT=3000
NODE_ENV=development

# JWT Secrets for Auth
JWT_SECRET=edumatch-secret-key-12345

# Google Gemini API Key (preferred AI provider; leave empty for smart offline simulation)
# Get one at https://aistudio.google.com/apikey and set it here or in your host's env vars.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the Gemini model (defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API Key (used only if GEMINI_API_KEY is empty; leave empty for smart offline simulation)
OPENAI_API_KEY=your_openai_api_key_here

# Stripe Keys (leave empty for smart mock-checkout billing simulation)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Stripe Product Pricing IDs
STRIPE_PRO_PRICE_ID=price_12345_pro
STRIPE_SCHOOL_PRICE_ID=price_12345_school
