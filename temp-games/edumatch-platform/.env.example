# Copy to .env (or export these in your host) and restart.

# Server
PORT=3000

# Auth — CHANGE THIS to a long random string in production
AUTH_SECRET=please-change-this-to-a-long-random-secret

# Database file (node:sqlite). For production prefer a managed Postgres.
DB_PATH=./edumatch.db

# First platform admin (created on first boot)
ADMIN_EMAIL=admin@edumatch.app
ADMIN_PASSWORD=admin1234

# AI auto-fill (optional). If unset, an offline sample generator is used.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Stripe billing (optional). If unset, subscriptions run in test/mock mode.
# STRIPE_SECRET_KEY=sk_live_or_test_...
